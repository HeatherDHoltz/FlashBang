<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="cs151.application.ReviewDeckController">

    <top>
        <VBox spacing="10" BorderPane.alignment="CENTER">
            <padding>
                <Insets top="15" right="15" bottom="10" left="15"/>
            </padding>

            <Label text="Deck Review"
                   style="-fx-font-size: 22px; -fx-font-weight: bold;" />

            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="Deck:" style="-fx-font-weight: bold;"/>
                <Label fx:id="deckNameLabel" text="Selected Deck"/>

                <Label text="   Filter:" style="-fx-font-weight: bold;"/>
                <ComboBox fx:id="filterBox" prefWidth="160"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <GridPane hgap="10" vgap="12">
            <padding>
                <Insets top="10" right="15" bottom="10" left="15"/>
            </padding>

            <Label text="Front:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
            <TextArea fx:id="frontArea"
                      prefRowCount="4"
                      wrapText="true"
                      GridPane.columnIndex="1"
                      GridPane.rowIndex="0"/>

            <Label text="Back:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
            <TextArea fx:id="backArea"
                      prefRowCount="4"
                      wrapText="true"
                      GridPane.columnIndex="1"
                      GridPane.rowIndex="1"/>

            <Label text="Status:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
            <ComboBox fx:id="statusBox"
                      prefWidth="160"
                      GridPane.columnIndex="1"
                      GridPane.rowIndex="2"/>

            <Label text="Creation Date:" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
            <Label fx:id="creationDateLabel"
                   text="N/A"
                   GridPane.columnIndex="1"
                   GridPane.rowIndex="3"/>

            <Label text="Last Reviewed:" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
            <Label fx:id="lastReviewLabel"
                   text="N/A"
                   GridPane.columnIndex="1"
                   GridPane.rowIndex="4"/>
        </GridPane>
    </center>

    <bottom>
        <HBox spacing="10" alignment="CENTER_RIGHT" BorderPane.alignment="CENTER">
            <padding>
                <Insets top="10" right="15" bottom="15" left="15"/>
            </padding>

            <Button fx:id="prevButton"
                    text="Previous"
                    onAction="#handlePrevious"/>

            <Button fx:id="nextButton"
                    text="Next"
                    onAction="#handleNext"/>

            <Button text="Save"
                    onAction="#handleSave"/>

            <Button text="Back"
                    onAction="#handleBack"/>
        </HBox>
    </bottom>

</BorderPane>