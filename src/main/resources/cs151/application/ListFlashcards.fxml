<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="cs151.application.ListFlashcardsController"
      spacing="10"
      alignment="CENTER"
      style="-fx-padding: 20;">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <children>
        <Label text="Search Flashcards" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

        <HBox spacing="10" alignment="CENTER">
            <children>
                <TextField fx:id="searchField"
                           promptText="Search by deck, front, back, or status"
                           prefWidth="420"
                           onAction="#handleSearch"/>
                <Button text="Search" onAction="#handleSearch"/>
            </children>
        </HBox>

        <TableView fx:id="table" prefWidth="640" prefHeight="260">

            <columns>
                <TableColumn fx:id="deckCol" text="Deck"/>
                <TableColumn fx:id="frontCol" text="Front"/>
                <TableColumn fx:id="backCol" text="Back"/>
                <TableColumn fx:id="dateCol" text="Date"/>
                <TableColumn fx:id="statusCol" text="Status"/>
                <TableColumn fx:id="lastReviewCol" text="Last Review Date"/>
            </columns>
        </TableView>

    <HBox spacing="10" alignment="CENTER">
        <children>
            <Button text="Review Flashcard" onAction="#handleReview"/>
            <Button text="Delete Flashcard" onAction="#handleDelete"/>
            <Button text="Back" onAction="#handleBack"/>
        </children>
    </HBox>
    </children>

</VBox>