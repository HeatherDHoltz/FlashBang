<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="10" xmlns:fx="http://javafx.com/fxml"
      fx:controller="cs151.application.EditFlashcardController">

    <Label text="Edit Flashcard" style="-fx-font-size: 20px; -fx-font-weight: bold;" />

    <Label text="Deck" />
    <ComboBox fx:id="deckBox" prefWidth="500" />

    <Label text="Front Text" />
    <TextArea fx:id="frontArea" prefHeight="100" prefWidth="500" />

    <Label text="Back Text" />
    <TextArea fx:id="backArea" prefHeight="100" prefWidth="500" />

    <Label text="Status" />
    <ComboBox fx:id="statusBox" prefWidth="500" />

    <HBox alignment="CENTER" spacing="10">
        <Button text="Save" onAction="#handleSave" />
        <Button text="Back" onAction="#handleBack" />
    </HBox>
</VBox>
