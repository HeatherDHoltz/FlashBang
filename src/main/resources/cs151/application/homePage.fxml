<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<HBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="cs151.application.HomePageController"
      spacing="60"
      alignment="CENTER"
      style="-fx-background-color: #cfe8f6;">

    <children>

        <!--Logo-->
        <ImageView fitHeight="300" preserveRatio="true">
            <image>
                <Image url="@FlashBangLogo.png"/>
            </image>
        </ImageView>

        <!--Button for create deck-->
        <VBox spacing="20" alignment="CENTER">

            <children>

                <Button text="Create A New FlashBang Deck"
                        prefWidth="300"
                        prefHeight="60"
                        wrapText="true"
                        onAction="#handleCreateDeck"
                        style="-fx-background-color: #e58a2f;
                               -fx-text-fill: white;
                               -fx-font-size: 16px;
                               -fx-font-weight: bold;" />

            </children>

        </VBox>

    </children>

</HBox>