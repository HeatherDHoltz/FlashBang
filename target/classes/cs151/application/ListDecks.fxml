<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="15" xmlns:fx="http://javafx.com/fxml"
      fx:controller="cs151.application.ListDeckController">

    <TableView fx:id="deckTable" prefHeight="300" prefWidth="600">
        <columns>
            <TableColumn fx:id="nameColumn" prefWidth="200" text="Deck Name" />
            <TableColumn fx:id="desCol" prefWidth="400" text="Description" />
        </columns>
    </TableView>

    <Button text="Edit Deck" onAction="#handleEditDeck" />
    <Button text="Delete Deck" onAction="#handleDeleteDeck" />
    <Button text="Back" onAction="#handleBack" />
</VBox>