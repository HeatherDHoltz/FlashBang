<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="cs151.application.DefineDeckController"
      spacing="20"
      alignment="CENTER"
      style="-fx-background-color: #cfe8f6; -fx-padding: 40;">

    <children>
        <Label text="Define Deck" style="-fx-font-size: 24px; -fx-font-weight: bold;" />
        <Label text="Deck Name (required):" />
        <TextField fx:id="deckNameField" promptText="Enter deck name" />
        <Label text="Description (optional):" />
        <TextArea fx:id="descriptionField" promptText="Enter description" prefRowCount="3" />
        <Button text="Save Deck" onAction="#handleSaveDeck" style="-fx-background-color: #e58a2f; -fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold;" />
    </children>

</VBox>

